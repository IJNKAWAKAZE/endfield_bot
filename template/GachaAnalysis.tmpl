<!DOCTYPE html>
<html lang="zh-cn">
<head>
    <meta charset="UTF-8">
    <title>抽卡分析 - 终末地</title>
    <style>
        @font-face {
            font-family: 'NotoSansHans';
            src: url('/assets/font/NotoSansHans-Regular.ttf');
        }

        :root {
            --bg: #15181d;
            --panel: #1d2229;
            --panel-soft: #242b34;
            --border: rgba(255, 255, 255, 0.08);
            --text: #edf2f7;
            --muted: #8b97a7;
            --char: #ff9f43;
            --weapon: #3fb6ff;
            --limited: #ff5d73;
            --base: #6bd18a;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 24px;
            font-family: 'NotoSansHans', 'Microsoft YaHei', sans-serif;
            background:
                radial-gradient(circle at top left, rgba(255, 159, 67, 0.14), transparent 28%),
                radial-gradient(circle at top right, rgba(63, 182, 255, 0.14), transparent 32%),
                linear-gradient(180deg, #11151a 0%, #181d24 100%);
            color: var(--text);
            display: flex;
            justify-content: center;
        }

        #main {
            width: 920px;
            background: rgba(20, 25, 31, 0.92);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 28px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            gap: 20px;
            margin-bottom: 28px;
        }

        .title {
            margin: 0;
            font-size: 34px;
            line-height: 1.1;
            letter-spacing: 1px;
        }

        .subtitle {
            margin-top: 8px;
            font-size: 13px;
            color: var(--muted);
            letter-spacing: 0.5px;
        }

        .profile {
            text-align: right;
            padding: 12px 16px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border);
            border-radius: 16px;
        }

        .profile-name {
            font-size: 26px;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .profile-meta {
            font-size: 12px;
            color: var(--muted);
        }

        .section {
            margin-top: 24px;
            padding: 22px;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0.01));
            border: 1px solid var(--border);
            border-radius: 20px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 18px;
        }

        .section-title {
            margin: 0;
            font-size: 24px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .section-title::before {
            content: "";
            width: 10px;
            height: 10px;
            border-radius: 999px;
            background: var(--char);
            box-shadow: 0 0 16px rgba(255, 159, 67, 0.7);
        }

        .section.weapon .section-title::before {
            background: var(--weapon);
            box-shadow: 0 0 16px rgba(63, 182, 255, 0.7);
        }

        .section-note {
            font-size: 12px;
            color: var(--muted);
        }

        .summary-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px;
            margin-bottom: 20px;
        }

        .summary-card {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 16px;
        }

        .summary-card .label {
            font-size: 12px;
            color: var(--muted);
            margin-bottom: 10px;
        }

        .summary-card .value {
            font-size: 32px;
            line-height: 1;
            font-weight: 800;
        }

        .summary-card .desc {
            margin-top: 8px;
            font-size: 11px;
            color: var(--muted);
        }

        .summary-card.limited {
            border-color: rgba(255, 93, 115, 0.35);
            background: linear-gradient(180deg, rgba(255, 93, 115, 0.12), rgba(255, 93, 115, 0.04));
        }

        .summary-card.limited .value {
            color: var(--limited);
        }

        .block-title {
            margin: 20px 0 12px;
            font-size: 16px;
            color: var(--text);
        }

        .pool-group {
            display: grid;
            grid-template-columns: 1fr;
            gap: 12px;
        }

        .pool-card {
            background: var(--panel-soft);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 16px;
        }

        .pool-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px;
        }

        .pool-name {
            font-size: 18px;
            font-weight: 700;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .badge.base {
            color: var(--base);
            background: rgba(107, 209, 138, 0.12);
        }

        .badge.limited {
            color: var(--limited);
            background: rgba(255, 93, 115, 0.12);
        }

        .pool-stats {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 12px;
        }

        .stat-chip {
            padding: 6px 10px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.05);
            color: #d9e1ea;
            font-size: 12px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            overflow: hidden;
            border-radius: 14px;
        }

        th,
        td {
            padding: 10px 12px;
            text-align: left;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        th {
            font-size: 12px;
            color: var(--muted);
            font-weight: 600;
            background: rgba(255, 255, 255, 0.03);
        }

        td {
            font-size: 13px;
        }

        tr:last-child td {
            border-bottom: none;
        }

        .rarity-6 {
            color: #ffd166;
            font-weight: 700;
        }

        .pity-tag {
            display: inline-block;
            margin-left: 8px;
            padding: 2px 8px;
            border-radius: 999px;
            font-size: 11px;
            background: rgba(255, 255, 255, 0.08);
            color: #dfe7f0;
        }

        .empty {
            padding: 18px 12px;
            text-align: center;
            color: var(--muted);
            font-size: 13px;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 14px;
        }

        .footer {
            margin-top: 22px;
            text-align: center;
            font-size: 12px;
            color: var(--muted);
        }
    </style>
</head>
<body>
    <div id="main">
        <div class="header">
            <div>
                <h1 class="title">抽卡分析</h1>
                <div class="subtitle">角色池 / 武器池，基础池 / 限定池分开展示</div>
            </div>
            <div class="profile">
                <div class="profile-name">{{.PlayerName}}</div>
                <div class="profile-meta">{{.ServerName}} | UID: {{.RoleId}}</div>
            </div>
        </div>

        {{range .Sections}}
        <section class="section {{if eq .TypeKey "weapon"}}weapon{{end}}">
            <div class="section-header">
                <h2 class="section-title">{{.TypeLabel}}</h2>
                <div class="section-note">限定池保底按该类型全部限定池继承计算</div>
            </div>

            <div class="summary-grid">
                <div class="summary-card">
                    <div class="label">总抽数</div>
                    <div class="value">{{.Stats.TotalCount}}</div>
                </div>
                <div class="summary-card">
                    <div class="label">6 星数量</div>
                    <div class="value">{{.Stats.SixStarCount}}</div>
                </div>
                <div class="summary-card">
                    <div class="label">平均出 6 星抽数</div>
                    <div class="value">{{printf "%.2f" .Stats.AveragePity}}</div>
                </div>
                <div class="summary-card limited">
                    <div class="label">限定总保底</div>
                    <div class="value">{{.LimitedCurrentPity}}</div>
                    <div class="desc">当前该类型全部限定池累计未出 6 星</div>
                </div>
            </div>

            <div class="block-title">最近获得的 6 星</div>
            {{if .RecentPulls}}
            <table>
                <thead>
                    <tr>
                        <th style="width: 22%;">时间</th>
                        <th style="width: 32%;">卡池</th>
                        <th style="width: 30%;">名称</th>
                        <th style="width: 16%;">抽数</th>
                    </tr>
                </thead>
                <tbody>
                    {{range .RecentPulls}}
                    <tr class="rarity-6">
                        <td>{{.TimeStr}}</td>
                        <td>{{.PoolName}}</td>
                        <td>{{.ItemName}}</td>
                        <td>{{.Pity}}</td>
                    </tr>
                    {{end}}
                </tbody>
            </table>
            {{else}}
            <div class="empty">暂无 6 星记录</div>
            {{end}}

            <div class="block-title">限定池</div>
            {{if .LimitedPools}}
            <div class="pool-group">
                {{range .LimitedPools}}
                <div class="pool-card">
                    <div class="pool-head">
                        <div class="pool-name">{{.Name}}</div>
                        <span class="badge limited">{{.CategoryLabel}}</span>
                    </div>
                    <div class="pool-stats">
                        <span class="stat-chip">总抽数 {{.Total}}</span>
                        <span class="stat-chip">本池已累计 {{.CurrentPity}} 抽未出 6 星</span>
                        <span class="stat-chip">6 星率 {{printf "%.2f" .SixStarRate}}%</span>
                    </div>
                    {{if .RecentSixStars}}
                    <table>
                        <thead>
                            <tr>
                                <th style="width: 28%;">时间</th>
                                <th style="width: 52%;">名称</th>
                                <th style="width: 20%;">抽数</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{range .RecentSixStars}}
                            <tr class="rarity-6">
                                <td>{{.TimeStr}}</td>
                                <td>{{.ItemName}}</td>
                                <td>{{.Pity}}</td>
                            </tr>
                            {{end}}
                        </tbody>
                    </table>
                    {{else}}
                    <div class="empty">该池还没有 6 星记录</div>
                    {{end}}
                </div>
                {{end}}
            </div>
            {{else}}
            <div class="empty">暂无限定池记录</div>
            {{end}}

            <div class="block-title">基础池</div>
            {{if .BasePools}}
            <div class="pool-group">
                {{range .BasePools}}
                <div class="pool-card">
                    <div class="pool-head">
                        <div class="pool-name">{{.Name}}</div>
                        <span class="badge base">{{.CategoryLabel}}</span>
                    </div>
                    <div class="pool-stats">
                        <span class="stat-chip">总抽数 {{.Total}}</span>
                        <span class="stat-chip">本池已累计 {{.CurrentPity}} 抽未出 6 星</span>
                        <span class="stat-chip">6 星率 {{printf "%.2f" .SixStarRate}}%</span>
                    </div>
                    {{if .RecentSixStars}}
                    <table>
                        <thead>
                            <tr>
                                <th style="width: 28%;">时间</th>
                                <th style="width: 52%;">名称</th>
                                <th style="width: 20%;">抽数</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{range .RecentSixStars}}
                            <tr class="rarity-6">
                                <td>{{.TimeStr}}</td>
                                <td>{{.ItemName}}</td>
                                <td>{{.Pity}}</td>
                            </tr>
                            {{end}}
                        </tbody>
                    </table>
                    {{else}}
                    <div class="empty">该池还没有 6 星记录</div>
                    {{end}}
                </div>
                {{end}}
            </div>
            {{else}}
            <div class="empty">暂无基础池记录</div>
            {{end}}
        </section>
        {{end}}

        <div class="footer">数据同步时间：{{.SyncTime}} | Endfield Bot</div>
    </div>
</body>
</html>
